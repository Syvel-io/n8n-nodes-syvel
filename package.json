{
  "name": "n8n-nodes-syvel",
  "version": "0.1.0",
  "description": "n8n community node for Syvel — disposable and risky email detection",
  "keywords": [
    "n8n-community-node-package",
    "disposable email",
    "email validation",
    "email verification",
    "email detection",
    "syvel"
  ],
  "license": "MIT",
  "homepage": "https://www.syvel.io",
  "author": {
    "name": "Syvel",
    "email": "contact@syvel.io",
    "url": "https://www.syvel.io"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Syvel-io/n8n-nodes-syvel.git"
  },
  "bugs": {
    "url": "https://github.com/Syvel-io/n8n-nodes-syvel/issues"
  },
  "main": "index.js",
  "scripts": {
    "build": "tsc && copyfiles -u 0 \"nodes/**/*.svg\" dist/",
    "dev": "tsc --watch",
    "format": "prettier nodes credentials tests --write",
    "lint": "ESLINT_USE_FLAT_CONFIG=false eslint nodes credentials tests --ext .ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "validate:build": "node scripts/validate-build.js",
    "release": "npm run build && changeset publish",
    "prepublishOnly": "npm run build && npm run validate:build"
  },
  "files": [
    "dist",
    "index.js"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/SyvelApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/Syvel/Syvel.node.js"
    ]
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@types/node": "^25.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitest/coverage-v8": "^3.0.0",
    "copyfiles": "^2.4.1",
    "eslint": "^9.0.0",
    "eslint-plugin-n8n-nodes-base": "^1.16.6",
    "n8n-workflow": "^2.0.0",
    "prettier": "^3.2.5",
    "typescript": "^6.0.2",
    "vitest": "^3.0.0"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  }
}
